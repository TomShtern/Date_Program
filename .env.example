# Copy this file to .env for local development.
# Local PostgreSQL is the default runtime path for this repository.
# Docker is an optional fallback only when no local PostgreSQL instance is available.
# Tracked JSON config files intentionally omit databasePassword.
# Supply DATING_APP_DB_PASSWORD via .env, an OS env var, or -Ddatingapp.db.password.
DATING_APP_DB_PROFILE=
# Default local helper scripts use the dev password below.
DATING_APP_DB_PASSWORD=datingapp
DATING_APP_DB_DIALECT=POSTGRESQL
DATING_APP_DB_URL=jdbc:postgresql://localhost:55432/datingapp
DATING_APP_DB_USERNAME=datingapp
DATING_APP_DB_MAX_POOL_SIZE=10
DATING_APP_DB_MIN_IDLE=2
DATING_APP_DB_CONNECTION_TIMEOUT_SECONDS=5
DATING_APP_DB_VALIDATION_TIMEOUT_SECONDS=3
DATING_APP_DB_IDLE_TIMEOUT_SECONDS=600
DATING_APP_DB_MAX_LIFETIME_SECONDS=1800
# TCP keepalive for idle pool connections. 0 = disabled (local dev only).
# In production, set to 30-60 to prevent firewall/load-balancer idle-connection drops.
DATING_APP_DB_KEEPALIVE_TIME_SECONDS=0

# Phone-alpha auth configuration
# Local/dev can keep the development placeholder from config/app-config*.json.
# Production must set a non-placeholder value here.
DATING_APP_ENV=development
# DATING_APP_AUTH_JWT_SECRET
# Temporary phone-alpha auth secret. Must be replaced before production.
# Minimum 32 characters of high entropy. Use a random base64 or hex string.
# Example generation: openssl rand -base64 32
# Keep this secret — do NOT commit real values. Rotate periodically.
# Provide via environment manager (Vault, AWS Secrets Manager, etc.) in production.
DATING_APP_AUTH_JWT_SECRET=REPLACE_ME_WITH_32_PLUS_CHAR_RANDOM_SECRET
