<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="rootPane" prefHeight="700.0" prefWidth="900.0"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="datingapp.ui.screen.NotesController">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-bar">
      <Button onAction="#handleBack" styleClass="button-transparent">
        <graphic>
          <FontIcon iconLiteral="mdi2c-chevron-left" iconSize="28" iconColor="white"/>
        </graphic>
      </Button>
      <FontIcon iconLiteral="mdi2n-note-text-outline" iconSize="24" iconColor="#38bdf8"/>
      <Label styleClass="subheading" text="My Notes"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button onAction="#handleOpenSelected" styleClass="button-secondary" text="Open Selected"/>
    </HBox>
  </top>

  <center>
    <StackPane>
      <padding>
        <Insets top="28" right="40" bottom="28" left="40"/>
      </padding>
      <ListView fx:id="notesListView" styleClass="transparent-scroll"/>
      <VBox fx:id="emptyStateBox" alignment="CENTER" managed="false" spacing="12" visible="false">
        <FontIcon iconLiteral="mdi2n-note-remove-outline" iconSize="54" iconColor="#64748b"/>
        <Label styleClass="empty-state-title" text="No notes yet"/>
        <Label styleClass="empty-state-subtitle" text="Save profile notes from Matching or Chat, then double-click a note here to reopen that profile."/>
      </VBox>
    </StackPane>
  </center>
</BorderPane>
